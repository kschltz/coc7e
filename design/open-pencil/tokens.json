{
  "colors": {
    "weird-red": "#D92525",
    "weird-darkred": "#8B1A1A",
    "weird-yellow": "#F2C94C",
    "weird-black": "#111111",
    "weird-paper": "#E8DCC4",
    "weird-border": "#3A2A18"
  },
  "alphaTokens": {
    "weird-red-alpha": "rgba(217, 37, 37, 0.1)",
    "weird-black-alpha-10": "rgba(17, 17, 17, 0.1)",
    "weird-black-alpha-20": "rgba(17, 17, 17, 0.2)",
    "weird-black-alpha-30": "rgba(17, 17, 17, 0.3)",
    "weird-black-alpha-50": "rgba(17, 17, 17, 0.5)",
    "weird-black-alpha-70": "rgba(17, 17, 17, 0.7)"
  },
  "fonts": {
    "display": "Cinzel Decorative",
    "accent": "IM Fell English",
    "body": "Libre Baskerville",
    "mono": "Courier Prime",
    "secondaryDisplay": "Playfair Display SC"
  },
  "components": {
    "button": {
      "radius": 0,
      "border": "3px solid weird-black",
      "shadow": "4px 4px 0 weird-black",
      "textStyle": "body bold uppercase tracking-wide"
    },
    "input": {
      "height": 32,
      "border": "2px solid weird-black",
      "shadow": "2px 2px 0 weird-black",
      "background": "weird-paper"
    },
    "panel": {
      "border": "4px solid weird-black",
      "shadow": "8px 8px 0 weird-black",
      "background": "weird-paper"
    },
    "quoteCard": {
      "border": "3px solid weird-red",
      "shadow": "6px 6px 0 weird-yellow",
      "background": "weird-black"
    }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24,
    "2xl": 32,
    "3xl": 48
  }
}
